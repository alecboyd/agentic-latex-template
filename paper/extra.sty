%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% LOCAL REFERENCE PDF LINKS
%
% Add a local PDF path to a bibliography entry with:
%   file = {references/citation-key.pdf}
%
% Local links are hidden by default so final/shared PDFs do not expose local
% document paths. Use \showlocalreferences in the manuscript preamble to print
% them in the bibliography, or \hidelocalreferences to hide them again.
\newif\iflocalreferencesvisible
\localreferencesvisiblefalse

\newcommand{\hidelocalreferences}{\localreferencesvisiblefalse}
\newcommand{\showlocalreferences}{\localreferencesvisibletrue}
\newcommand{\localreferenceuriprefix}{run:./}
\newcommand{\setlocalreferenceuriprefix}[1]{%
  \renewcommand{\localreferenceuriprefix}{#1}%
}

\makeatletter
\AtBeginDocument{%
  \@ifpackageloaded{biblatex}{%
    \renewbibmacro*{finentry}{%
      \iflocalreferencesvisible
        \iffieldundef{file}
          {}
          {\setunit{\addspace}\printtext{\mkbibbrackets{\href{\localreferenceuriprefix\thefield{file}}{Local copy}}}}%
      \fi
      \finentry
    }%
  }{}%
}
\makeatother
