% TODO SYSTEM
\RequirePackage{xparse}

\makeatletter

\newcounter{todocounter}
\newcommand{\alltodos}{}

% This gets executed from the .aux file on the next run.
\newcommand{\todoauxentry}[2]{%
  \g@addto@macro\alltodos{\todoListRow{#1}{#2}}%
}

% Inline format.
\newcommand{\todoformat}[2]{%
  \ifinner
    {\footnotesize\textbf{TODO: #1} #2}%
  \else
    \marginpar{\raggedright\footnotesize\textbf{TODO: #1}\\#2}%
  \fi
}

% One row in the printed list.
\newcommand{\todoListRow}[2]{%
  \hypertarget{todolist.#1}{}\hyperlink{todo.#1}{\textbf{#1}} & #2\\%
}

% Print the list wherever desired.
\newcommand{\listoftodos}{%
  \section*{Todo List}
  \begin{tabularx}{\textwidth}{@{}p{1.8cm}X@{}}
    \toprule
    \textbf{\#} & \textbf{Caption} \\
    \midrule
    \ifx\alltodos\@empty
      \multicolumn{2}{@{}l@{}}{\textit{No todos found.}}\\
    \else
      \alltodos
    \fi
    \bottomrule
  \end{tabularx}
}

% Internal command.
\newcommand{\todo@do}[1]{%
  \refstepcounter{todocounter}%
  \hypertarget{todo.\thetodocounter}{}%
  \protected@write\@auxout{}{%
    \string\todoauxentry{\thetodocounter}{#1}%
  }%
  \todoformat{\hyperlink{todolist.\thetodocounter}{\thetodocounter}}{#1}%
}

% Allow both \todo{...} and \todo[...].
\NewDocumentCommand{\todo}{ d[] g }{%
  \IfNoValueTF{#1}
    {%
      \IfNoValueTF{#2}
        {\PackageError{todo}{Missing todo caption}{}}
        {\todo@do{#2}}%
    }
    {\todo@do{#1}}%
}

\makeatother
