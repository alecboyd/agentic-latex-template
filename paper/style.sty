%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CLEVEREF SETUP
\RequirePackage{amsthm} % NEEDS TO BE LOADED BEFORE CLEVEREF
\RequirePackage{amsmath} % NEEDS TO BE LOADED BEFORE CLEVEREF
\RequirePackage[capitalise]{cleveref} % NEEDS TO BE LOADED BEFORE `newtheorem` DEFINITIONS
\RequirePackage{aliascnt}
\creflabelformat{equation}{#2\textup{(#1)}#3}
\newcommand{\crefrangeconjunction}{--} % Use en-dash when referencing multiple items in a range
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% ENVIRONMENT SETUP
\RequirePackage[T1]{fontenc} % Required for sans serifs (I think)
\RequirePackage{indentfirst}
\RequirePackage{titlesec}
\RequirePackage{etoolbox}
\RequirePackage{fancyhdr}

\newtheoremstyle{customtheorem}% name of the style to be used
  {.75\baselineskip}% measure of space to leave above the theorem
  {.75\baselineskip}% measure of space to leave below the theorem
  {\itshape}% theorem body
  {0pt}% measure of space to indent
  {\color{black}\bfseries}% name of head font
  {.}% punctuation between head and body
  { }% space after theorem head; " " = normal interword space
  {$\blacktriangleright$ \thmname{#1}\thmnumber{ #2}\textmd{\thmnote{ (#3)}}}

\newtheoremstyle{customplainblock}% theorem-like heading, upright body
  {.75\baselineskip}%
  {.75\baselineskip}%
  {\upshape}%
  {0pt}%
  {\color{black}\bfseries}%
  {.}%
  { }%
  {\thmname{#1}\thmnumber{ #2}\textmd{\thmnote{ (#3)}}}

% Theorems, propositions, lemmas, claims, conjectures, and corollaries all
% use the standard theorem style
\theoremstyle{customtheorem}
\newtheorem{theorem}{Theorem}[section]
\theoremstyle{customtheorem}
\newaliascnt{proposition}{theorem}
\newtheorem{proposition}[proposition]{Proposition}
\aliascntresetthe{proposition}
\theoremstyle{customtheorem}
\newaliascnt{lemma}{theorem}
\newtheorem{lemma}[lemma]{Lemma}
\aliascntresetthe{lemma}
\theoremstyle{customtheorem}
\newaliascnt{claim}{theorem}
\newtheorem{claim}[claim]{Claim}
\aliascntresetthe{claim}
\theoremstyle{customtheorem}
\newaliascnt{conjecture}{theorem}
\newtheorem{conjecture}[conjecture]{Conjecture}
\aliascntresetthe{conjecture}
\theoremstyle{customtheorem}
\newaliascnt{corollary}{theorem}
\newtheorem{corollary}[corollary]{Corollary}
\aliascntresetthe{corollary}

% Definitions, examples, and remarks share the same section-resetting counter
% as the result-style environments, but keep upright body text.
\theoremstyle{customplainblock}
\newtheorem{definition}[theorem]{Definition}
\theoremstyle{customplainblock}
\newtheorem{example}[theorem]{Example}
\theoremstyle{customplainblock}
\newtheorem{remark}[theorem]{Remark}
\theoremstyle{customplainblock}
\newtheorem{assumption}[theorem]{Assumption}
\theoremstyle{customplainblock}
\newtheorem{context}[theorem]{Context}

% Make \cref use capitalized labels by default.
\crefname{theorem}{Theorem}{Theorems}
\crefname{proposition}{Proposition}{Propositions}
\crefname{lemma}{Lemma}{Lemmas}
\crefname{claim}{Claim}{Claims}
\crefname{conjecture}{Conjecture}{Conjectures}
\crefname{corollary}{Corollary}{Corollaries}
\crefname{definition}{Definition}{Definitions}
\crefname{example}{Example}{Examples}
\crefname{remark}{Remark}{Remarks}
\crefname{assumption}{Assumption}{Assumptions}
\crefname{context}{Context}{Contexts}
\crefname{equation}{Equation}{Equations}

% Ensure theorem-like hyperref destinations stay unique when theorem counters
% reset by section.
\makeatletter
\AtBeginDocument{%
  \def\theHtheorem{\thesection.\arabic{theorem}}%
  \def\theHproposition{\theHtheorem}%
  \def\theHlemma{\theHtheorem}%
  \def\theHclaim{\theHtheorem}%
  \def\theHconjecture{\theHtheorem}%
  \def\theHcorollary{\theHtheorem}%
  \def\theHdefinition{\theHtheorem}%
  \def\theHexample{\theHtheorem}%
  \def\theHremark{\theHtheorem}%
  \def\theHassumption{\theHtheorem}%
  \def\theHcontext{\theHtheorem}%
}
\makeatother

% These are changes to the proof environment
\let\oldproofname=\proofname
% Changes the formatting for the 'Proof.' text at the start of the environment
\renewcommand{\proofname}{\color{black}\bfseries\upshape{\oldproofname}}
% Changes the qed symbol to be a left pointing triangle
\renewcommand{\qedsymbol}{\color{black}$\blacktriangleleft$}

% Paper layout: compact paragraph indentation with centered AMS-like headings.
\setlength{\parindent}{1.5em}
\setlength{\parskip}{0pt}

\titleformat{\section}
  {\normalfont\large\bfseries\centering}
  {\thesection.}
  {0.5em}
  {}
\titleformat{\subsection}
  {\normalfont\normalsize\bfseries\centering}
  {\thesubsection.}
  {0.5em}
  {}
\titlespacing*{\section}{0pt}{1.4\baselineskip}{0.75\baselineskip}
\titlespacing*{\subsection}{0pt}{1.1\baselineskip}{0.5\baselineskip}

\makeatletter
\def\@shorttitle{}
\def\@shortauthors{}
\newcommand{\shorttitle}[1]{\gdef\@shorttitle{#1}}
\newcommand{\shortauthors}[1]{\gdef\@shortauthors{#1}}
\newcommand{\runningheadfont}{\normalfont\footnotesize\scshape}

\setlength{\headheight}{14pt}
  \AtBeginDocument{%
  \ifx\@shorttitle\@empty
    \gdef\@shorttitle{\@title}%
  \fi
  \ifx\@shortauthors\@empty
    \gdef\@shortauthors{\@author}%
  \fi
  \pagestyle{fancy}%
  \fancyhf{}%
  \fancyhead[CE]{\runningheadfont \MakeUppercase{\@shortauthors}}%
  \fancyhead[CO]{\runningheadfont \MakeUppercase{\@shorttitle}}%
  \fancyfoot[C]{\runningheadfont \thepage}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
  \fancypagestyle{plain}{%
    \fancyhf{}%
    \fancyfoot[C]{\runningheadfont \thepage}%
    \renewcommand{\headrulewidth}{0pt}%
    \renewcommand{\footrulewidth}{0pt}%
  }%
}
\renewcommand{\maketitle}{%
  \begin{center}%
    {\normalfont\large\bfseries\MakeUppercase{\@title}\par}%
    \vspace{1.1\baselineskip}%
    {\normalfont\scshape\MakeUppercase{\@author}\par}%
    \ifx\@date\@empty\else
      \vspace{0.5\baselineskip}%
      {\normalfont\small \@date\par}%
    \fi
  \end{center}%
  \thispagestyle{plain}%
  \vspace{1.2\baselineskip}%
}
\newcommand{\suppressindentafterdisplay}{\@doendpe}
\let\latexdisplayend\]
\renewcommand{\]}{\aftergroup\suppressindentafterdisplay\latexdisplayend}
\makeatother

\AfterEndEnvironment{equation}{\suppressindentafterdisplay}
\AfterEndEnvironment{equation*}{\suppressindentafterdisplay}
\AfterEndEnvironment{align}{\suppressindentafterdisplay}
\AfterEndEnvironment{align*}{\suppressindentafterdisplay}
\AfterEndEnvironment{gather}{\suppressindentafterdisplay}
\AfterEndEnvironment{gather*}{\suppressindentafterdisplay}
\AfterEndEnvironment{multline}{\suppressindentafterdisplay}
\AfterEndEnvironment{multline*}{\suppressindentafterdisplay}

